# Copy to .env.local for local dev, and set the same vars in Vercel → Settings
# → Environment Variables for production. Accounts/cloud sync are optional — the
# app runs fully offline without any of these.

# --- Auth.js (NextAuth v5) ---
# Generate: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# GitHub OAuth app — https://github.com/settings/developers
# Authorization callback URL: https://YOUR_DOMAIN/api/auth/callback/github
# (for local dev: http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Cloud backup store (Neon / Vercel Postgres) ---
# Neon connection string, e.g. postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require
# (Vercel Postgres sets POSTGRES_URL automatically; either is read.)
DATABASE_URL=

# --- AI assistant (optional; BYO-key means leave these unset) ---
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
